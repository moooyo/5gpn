# 5gpn-dns config file — copy to /etc/5gpn/dns.env and edit.
# This is the SINGLE source of truth: install.sh writes it, and all sub-scripts
# (renew-hook.sh, update-lists.sh) read it. There are no separate .state files.
# 'systemctl reload 5gpn-dns' (SIGHUP) reloads ONLY the rule files under
# /etc/5gpn/rules/ + chnroute — NOT this file. A daemon knob changed here needs
# 'systemctl restart 5gpn-dns' (knobs are read once at startup); cert knobs need
# a re-run of install.sh. (The TLS certs themselves auto-reload on mtime.)

# --- Listener addresses ---
# DoT is the ONLY client-facing DNS transport (DoH/plain-:53 removed 2026-07-10).
# DNS_LISTEN_DEBUG is a loopback plain-UDP listener for on-box troubleshooting.
DNS_LISTEN_DOT=:853
DNS_LISTEN_DEBUG=127.0.0.1:5353
# Control-plane API + web console. Reached at
# https://DNS_CONSOLE_DOMAIN via the mihomo :443 SNI split, which routes the
# raw TLS stream straight to this loopback port (no PROXY protocol — source-IP
# gating happens in mihomo's whitelist.txt rule-provider BEFORE the connection
# ever reaches this listener, not via a header the daemon has to trust). The
# zash role certificate is shared with the mihomo controller; verified clients
# use DNS_ZASH_DOMAIN for TLS identity and trust DNS_ZASH_CERT.
# Binds loopback only; set DNS_LISTEN_API=:443 to opt into a public listener if
# you deliberately need direct access instead of the SNI-split path.
DNS_LISTEN_API=127.0.0.1:443

# --- TLS certificates (ONE mandatory WILDCARD lineage, THREE role dirs) ---
# *.<DNS_BASE_DOMAIN> (Cloudflare DNS-01) is deployed to dot/ (DoT :853 + iOS
# profile signing), web/ (control console, DNS_WEB_DOMAIN == DNS_CONSOLE_DOMAIN)
# and zash/ (zashboard panel + mihomo controller). Paths written by install.sh
# after cert issuance + renew-hook.sh after renewal. The daemon hot-reloads on
# file-mtime change. DNS_WEB_CERT/KEY empty => fall back to DNS_CERT/KEY
# (single-cert debug boxes).
DNS_CERT=/etc/5gpn/cert/dot/fullchain.pem
DNS_KEY=/etc/5gpn/cert/dot/privkey.pem
DNS_WEB_CERT=/etc/5gpn/cert/web/fullchain.pem
DNS_WEB_KEY=/etc/5gpn/cert/web/privkey.pem
# DNS_ZASH_CERT/KEY empty => fall back to DNS_WEB_CERT/KEY, then DNS_CERT/KEY.
# The zash role is the trust anchor for the shared zashboard panel + mihomo
# controller path.
DNS_ZASH_CERT=/etc/5gpn/cert/zash/fullchain.pem
DNS_ZASH_KEY=/etc/5gpn/cert/zash/privkey.pem

# --- Deployment identity + cert mode (read by install.sh / renew-hook.sh;
# DNS_BASE_DOMAIN / DNS_WEB_DOMAIN / DNS_GATEWAY_IP / DNS_PUBLIC_IP are also
# read by the Telegram bot). Older installs keep the operator-owned mihomo
# config byte-for-byte on ordinary reinstall/change-* and do not migrate the
# controller automatically; verified Controller clients fail closed until
# DNS_ZASH_DOMAIN is set and the raw config is migrated with explicit
# `mihomo-reset` or a manual TLS-only edit. If the verified Mihomo controller
# transport/client still cannot be built after that (missing domain, unreadable
# cert, invalid loopback controller), DNS keeps starting while Mihomo health/
# config/proxy endpoints stay unavailable rather than falling back to plaintext. ---
DNS_BASE_DOMAIN=       # operator's apex; console./zash./profile./dot.<base> are auto-derived
DNS_DOMAIN=            # DoT domain (dot.<base>; cert CN of the dot lineage)
DNS_WEB_DOMAIN=        # WebUI domain (== DNS_CONSOLE_DOMAIN; cert CN of the web lineage; mihomo SNI-split target)
DNS_CONSOLE_DOMAIN=    # console.<base> (same value as DNS_WEB_DOMAIN)
DNS_ZASH_DOMAIN=       # zash.<base> (zashboard panel domain; auto-derived from DNS_BASE_DOMAIN when empty)
DNS_PROFILE_DOMAIN=    # profile.<base>; public profile-only bootstrap host
# install.sh requires its A record to resolve to PUBLIC_IP or a client-routable
# GATEWAY_IP. SKIP_PROFILE_DNS_CHECK=1 is only for CI/explicit staged rollout.
DNS_PUBLIC_IP=        # public IP (cert A-record target); auto-detected at install,
                      # change later via '5gpn change-public-ip'
DNS_GATEWAY_IP=       # client-facing address; proxy/foreign names return this so
                      # mihomo (data plane, direct egress) intercepts + forwards them.
DNS_MIHOMO_LISTEN_IPS= # comma-separated LOCAL IPv4 addresses where mihomo binds :80/:443;
                       # normally includes DNS_GATEWAY_IP, never a non-local NAT address
CERT_MODE=cloudflare  # cloudflare (wildcard via Let's Encrypt DNS-01 through the
                      # Cloudflare API; no :80, no public A-record needed for
                      # console/zash/dot; auto-renews unattended) | debug (self-signed)
CERT_EMAIL=           # Let's Encrypt registration email

# Cloudflare API token for DNS-01 cert issuance (CERT_MODE=cloudflare).
# NEVER written to this dns.env file — stored in /etc/5gpn/acme/cloudflare.ini
# (directory 0700, file 0600, root-only). Two ways to supply it:
#   Interactive install: the installer prompts automatically on first issuance
#                        (or use '5gpn --set-cf-token' at any time).
#   Headless / CI install: export CF_API_TOKEN=<token>  (or CLOUDFLARE_API_TOKEN=)
#                          The token is copied to cloudflare.ini — not persisted
#                          here or logged. Required scope: Zone:DNS:Edit.
# Certificate reuse (a still-valid lineage or preserved /etc/5gpn/cert copy)
# never needs the token.
# CF_API_TOKEN=   (installer env var only — not stored here)

# --- Upstream resolvers ---
# China: fast domestic resolvers (comma-separated; used for CN domains).
DNS_CHINA=223.5.5.5,119.29.29.29

# Trust: resolvers for non-CN answers. Bare IP[:port] means plain UDP; the
# serverName@IP[:port] form means DoT (default DoT port 853).
DNS_TRUST=dns.google@8.8.8.8,one.one.one.one@1.1.1.1
# Web-managed overrides. If present, these files override the matching env
# defaults at startup; empty disables each override mechanism.
DNS_UPSTREAMS=/etc/5gpn/upstreams.json
DNS_ECS_FILE=/etc/5gpn/ecs.json

# DNS 0x20 anti-spoof on the plaintext-UDP china group: randomly cases the
# outgoing query name and requires the reply to echo it, raising the bar for
# off-path cache poisoning of CN verdicts. Default ON (1) — a startup self-probe
# auto-disables it if a configured china upstream is found to normalise query-
# name case (which would otherwise funnel CN domains through the gateway), so
# default-on cannot degrade resolution. Set 0 to force it off.
DNS_CHINA_0X20=1

# --- Rule files ---
DNS_RULES_DIR=/etc/5gpn/rules

# Path to the chnroute IPv4 list (used for split-horizon routing).
DNS_CHNROUTE=/etc/5gpn/rules/china_ip_list.txt

# --- Remote rule-list subscriptions ---
# Path to subscriptions.json (fetched in-process; caches land in
# DNS_RULES_DIR/<category>/<name>.txt and are merged with the manual
# <category>.txt files above). install.sh seeds only the system chnroute
# subscription here. Operator policy subscriptions live in DNS_POLICY_RULES
# and are compiled into managed subscription entries during policy Apply:
#
# {
#   "subscriptions": [
#     { "id": "china-ip", "category": "chnroute", "name": "china_ip_list",
#       "url": "https://raw.githubusercontent.com/17mon/china_ip_list/master/china_ip_list.txt",
#       "format": "cidr", "enabled": true, "interval": "24h" }
#   ]
# }
#
# Supported domain formats: plain | gfwlist | dnsmasq | adblock | hosts;
# chnroute uses cidr. Disable any entry (enabled:false) or edit via the Web/Bot
# console; a failed/too-small fetch keeps the prior cache (offline-safe).
DNS_SUBSCRIPTIONS=/etc/5gpn/subscriptions.json
DNS_POLICY_RULES=/etc/5gpn/policy.json

# --- Control-plane HTTPS API + web console ---
# Bearer token for the control-plane API on DNS_LISTEN_API. Empty disables the
# control plane (never served unauthenticated). install.sh auto-generates one
# on first install (openssl rand -hex 32) and preserves it across re-installs
# (never rotates a working token).
DNS_API_TOKEN=

# API per-source rate limit (token bucket, applied before auth); <=0 disables it.
DNS_API_RATE=20
DNS_API_BURST=40

# --- Mihomo data plane ---
# Mihomo's loopback external-controller API (DNS_MIHOMO_CONTROLLER) + its
# bearer secret (DNS_MIHOMO_SECRET) + the panel source-IP allowlist file
# (DNS_WHITELIST_FILE) mihomo's rule-provider reloads from. DNS_MIHOMO_CONTROLLER
# remains the loopback dial target; the verified controller uses DNS_ZASH_DOMAIN
# for TLS SNI/identity and DNS_ZASH_CERT for trust. Mihomo v1.19.28 also needs
# SAFE_PATHS=/etc/5gpn/cert/zash in its systemd unit because that shared cert
# lives outside -d /etc/5gpn/mihomo. Access control for the
# control console + zashboard panel now lives HERE (mihomo whitelist.txt,
# TUI-managed via '5gpn --add-allow <cidr>' / '5gpn --del-allow <cidr>'), not
# in an in-process login-failure lockout — the old fail2ban-style
# DNS_AUTH_FAIL_LIMIT/DNS_AUTH_FAIL_WINDOW/DNS_AUTH_BLOCK knobs (and the PROXY
# protocol v1 real-client-IP plumbing they depended on) are removed. Ordinary
# reinstall/change-* keep an existing operator-owned mihomo config byte-for-byte
# and do not migrate it.
DNS_MIHOMO_CONTROLLER=127.0.0.1:9090
DNS_MIHOMO_SECRET=
DNS_WHITELIST_FILE=/etc/5gpn/mihomo/whitelist.txt

# --- Stats persistence ---
# Reason-level counters + observability metrics persisted here across restarts;
# empty = don't persist (counters start at zero each boot).
DNS_STATS_FILE=/etc/5gpn/stats.json

# --- iOS profile files + Telegram control bot ---
# WWW_DIR is the .mobileconfig directory the daemon serves at the web console's
# profile-only host path (https://profile.<base>/ios/ios-dot.mobileconfig — the
# console also mounts /ios/ for compatibility; standalone :8111 was removed).
# Telegram bot runs as a goroutine of
# 5gpn-dns: empty TGBOT_TOKEN disables it; TGBOT_ADMINS is a comma-separated
# list of authorized numeric Telegram IDs. Set the bot via 'install.sh --setup-tgbot'.
WWW_DIR=/opt/5gpn/www
TGBOT_TOKEN=
TGBOT_ADMINS=
DNS_TGBOT_FILE=/etc/5gpn/tgbot.json

# --- Control-console SPA (served from disk by the loopback :443 server behind
# the mihomo SNI split) ---
# Directory install.sh extracts the 5gpn-web release tarball into. An unpopulated
# dir serves a built-in placeholder; the API works regardless.
DNS_WEB_DIR=/opt/5gpn/web

# --- zashboard panel (Zephyruso/zashboard, a mihomo/Clash web dashboard) ---
# Pinned dist.zip unpacked to DNS_ZASH_DIR, served as a SECOND loopback HTTPS
# listener on DNS_ZASH_LISTEN. Its /proxy/ path is a transparent controller
# proxy: zashboard presents DNS_MIHOMO_SECRET itself. The console does not get
# that broad capability; it uses bearer-protected health/config APIs and a
# short-lived one-use ticket for the read-only /proxy/logs WebSocket. Reached
# at https://DNS_ZASH_DOMAIN via the mihomo :443 SNI split, with the shared
# zash role certificate.
DNS_ZASH_DIR=/opt/5gpn/zash
DNS_ZASH_LISTEN=127.0.0.2:443

# --- Cache / performance ---
DNS_CACHE_SIZE=4096
DNS_TTL_MIN=300
DNS_TTL_MAX=86400
DNS_QUERY_TIMEOUT=5s

# --- Liveness heartbeat (dead-man's switch) ---
# When set, the daemon GETs this URL every DNS_HEARTBEAT_INTERVAL while alive; an
# external monitor (healthchecks.io, Uptime Kuma push endpoint, self-hosted)
# alerts when the pings STOP. This is the only signal that survives a box-down or
# crash-loop — the Telegram bot dies with the daemon, so it cannot report the
# box being gone. Empty disables.
DNS_HEARTBEAT_URL=
DNS_HEARTBEAT_INTERVAL=60s
# DNS_MAX_INFLIGHT: max concurrent in-flight resolutions (admission control);
# 0 disables shedding. Note: this is a GLOBAL cap, not per-source — there is no
# per-client fairness, so one runaway client can occupy the whole in-flight
# budget (all others get REFUSED) or thrash the shared cache.
DNS_MAX_INFLIGHT=4096

# DNS_EGRESS_BROKER: loopback resolver used by mihomo for sniffed origins.
# mihomo resolves sniffed origins through this (dns.nameserver in config.yaml
# always points here). Must be loopback IPv4. Empty disables.
DNS_EGRESS_BROKER=127.0.0.1:5354

# DNS_MIHOMO_CONFIG is the complete operator-owned mihomo configuration edited
# through the console's raw config page. Updates are validated with `mihomo -t`
# and hot-applied through the loopback controller.
DNS_MIHOMO_CONFIG=/etc/5gpn/mihomo/config.yaml

# Note: DNS_EGRESS_RESOLVER is mihomo's sniffed-origin SNI re-resolver (the
# current name for the old XRAY_RESOLVER knob, which is read only as a
# compatibility fallback). It is consumed by 5gpn-dns: the loopback Egress DNS
# Broker builds its fallback exchanger from it.
# Set it via '5gpn change-resolver' (which restarts 5gpn-dns).
# Empty/default 22.22.22.22 is a non-functional sentinel; set a real plain IPv4
# or https://…/dns-query DoH endpoint.
DNS_EGRESS_RESOLVER=22.22.22.22
# MIHOMO_VERSION= and MIHOMO_SHA256= are installer-only pins. There is NO host
# firewall management (removed 2026-07-10) — use your provider's security group
# if you need one; the control console + zashboard panel are instead gated by
# mihomo's whitelist.txt source-IP rule-provider (DNS_WHITELIST_FILE above).
# CERT_MODE is cloudflare (default, wildcard via DNS-01) | debug — http-01/
# dns-01(non-Cloudflare)/import were all removed.

# Invalid values for the numeric knobs above (cache/ttl/inflight/timeout) and
# the API rate/burst are non-fatal: 5gpn-dns logs a
# warning and falls back to the default rather than refusing to start — a single
# typo must never crash the network's only resolver into a restart loop.
