# 5gpn-dns environment file — copy to /etc/5gpn/dns.env and edit.
# install.sh writes this file automatically during full_install; use as reference
# for manual overrides or re-deployment.

# --- Listener addresses ---
DNS_LISTEN_DOT=:853
DNS_LISTEN_DOH=:8443
DNS_LISTEN_PLAIN=:53
DNS_LISTEN_DEBUG=127.0.0.1:5353
DNS_LISTEN_API=:9443

# --- TLS certificate (for DoT :853 and DoH :8443) ---
# Paths written by install.sh after cert issuance + renew-hook.sh after renewal.
DNS_CERT=/etc/5gpn/cert/fullchain.pem
DNS_KEY=/etc/5gpn/cert/privkey.pem

# --- Routing ---
# IP of this gateway; CHINA-resolved addresses return this IP to clients so
# sing-box (data plane, direct egress) intercepts and forwards them.
DNS_GATEWAY_IP=

# --- Upstream resolvers ---
# China: fast domestic resolvers (comma-separated; used for CN domains).
DNS_CHINA=223.5.5.5,119.29.29.29

# Trust: encrypted resolvers for non-CN / blocked domains (host@ip format).
DNS_TRUST=dns.google@8.8.8.8,one.one.one.one@1.1.1.1

# --- Rule files ---
DNS_RULES_DIR=/etc/5gpn/rules

# Path to the chnroute IPv4 list (used for split-horizon routing).
DNS_CHNROUTE=/etc/5gpn/rules/china_ip_list.txt

# --- Phase 2: remote rule-list subscriptions ---
# Path to subscriptions.json (fetched in-process; caches land in
# DNS_RULES_DIR/<category>/<name>.txt and are merged with the manual
# <category>.txt files above). install.sh writes a default file with one
# enabled chnroute subscription (china_ip_list). Example shape, including
# disabled entries for the other categories:
#
# {
#   "subscriptions": [
#     { "id": "china-ip", "category": "chnroute", "name": "china_ip_list",
#       "url": "https://raw.githubusercontent.com/17mon/china_ip_list/master/china_ip_list.txt",
#       "format": "cidr", "enabled": true, "interval": "24h" },
#     { "id": "easylist-cn", "category": "adblock", "name": "easylist_cn",
#       "url": "https://example.com/easylist-cn.txt",
#       "format": "plain", "enabled": false, "interval": "24h" },
#     { "id": "direct-cdn", "category": "direct", "name": "cdn_domains",
#       "url": "https://example.com/direct-cdn.txt",
#       "format": "plain", "enabled": false, "interval": "24h" },
#     { "id": "extra-blacklist", "category": "blacklist", "name": "extra_blacklist",
#       "url": "https://example.com/extra-blacklist.txt",
#       "format": "plain", "enabled": false, "interval": "24h" }
#   ]
# }
DNS_SUBSCRIPTIONS=/etc/5gpn/subscriptions.json

# --- Phase 3: control-plane HTTPS API ---
# Bearer token for the control-plane API on DNS_LISTEN_API. Empty disables the
# control plane. install.sh auto-generates one on first install (openssl rand
# -hex 32) and preserves it across re-installs (never rotates a working
# token). Reachable from CLIENT_NET only on :9443 (see scripts/setup-firewall.sh) —
# never exposed publicly.
DNS_API_TOKEN=

# --- Cache / performance ---
DNS_CACHE_SIZE=4096
DNS_TTL_MIN=300
DNS_TTL_MAX=86400
DNS_QUERY_TIMEOUT=5s
