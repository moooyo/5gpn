# 5gpn-dns environment file — copy to /etc/5gpn/dns.env and edit.
# install.sh writes this file automatically during full_install; use as reference
# for manual overrides or re-deployment.

# --- Listener addresses ---
DNS_LISTEN_DOT=:853
DNS_LISTEN_DOH=:8443
DNS_LISTEN_PLAIN=:53
DNS_LISTEN_DEBUG=127.0.0.1:5353

# --- TLS certificate (for DoT :853 and DoH :8443) ---
# Paths written by install.sh after cert issuance + renew-hook.sh after renewal.
DNS_CERT=/etc/5gpn/cert/fullchain.pem
DNS_KEY=/etc/5gpn/cert/privkey.pem

# --- Routing ---
# IP of this gateway; CHINA-resolved addresses return this IP to clients so
# sing-box (data plane, direct egress) intercepts and forwards them.
DNS_GATEWAY_IP=

# --- Upstream resolvers ---
# China: fast domestic resolvers (comma-separated; used for CN domains).
DNS_CHINA=223.5.5.5,119.29.29.29

# Trust: encrypted resolvers for non-CN / blocked domains (host@ip format).
DNS_TRUST=dns.google@8.8.8.8,one.one.one.one@1.1.1.1

# --- Rule files ---
DNS_RULES_DIR=/etc/5gpn/rules

# Path to the chnroute IPv4 list (used for split-horizon routing).
DNS_CHNROUTE=/etc/5gpn/rules/china_ip_list.txt

# --- Cache / performance ---
DNS_CACHE_SIZE=4096
DNS_TTL_MIN=300
DNS_TTL_MAX=86400
DNS_QUERY_TIMEOUT=5s
