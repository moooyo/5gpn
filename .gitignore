# Python
__pycache__/
*.py[cod]

# Editor / OS
*.swp
*~
.DS_Store

# Local scratch / temp
*.tmp
*.log

# Go build outputs (5gpn-dns is built in CI / cross-compiled; never commit binaries)
/cmd/5gpn-dns/5gpn-dns
/cmd/5gpn-dns/5gpn-dns.exe
*.exe

# Frontend build output (Phase 3 web UI; built in CI)
/web/node_modules/
/web/dist/

# Phase 3 control-plane SPA (cmd/5gpn-dns/web/dist) — built in CI via vite build;
# committed placeholder index.html keeps `go build` (go:embed) working pre-frontend-build.
/cmd/5gpn-dns/web/node_modules/
/cmd/5gpn-dns/web/dist/*
!/cmd/5gpn-dns/web/dist/index.html
